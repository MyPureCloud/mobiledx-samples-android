<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SubmitButtonStyle" parent="@style/submit_view">
        <item name="android:layout_gravity">center</item>
        <item name="android:textColor">@color/submit_button_text</item>
    </style>

    <style name="submit_view" parent="main_button">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/colorTextLight</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">@dimen/text_default_size</item>
    </style>

    <style name="main_button">
        <item name="android:textColor">@color/main_button_text_selector</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/main_button_text</item>
    </style>
</resources>